{
  "name": "prodigy-origin-extension",
  "version": "4.3.0",
  "private": true,
  "description": "Plasmo-based Play Origin browser extension",
  "scripts": {
    "dev": "plasmo dev",
    "dev:firefox": "plasmo dev --target=firefox-mv3",
    "build": "plasmo build",
    "build:firefox": "plasmo build --target=firefox-mv3",
    "package": "plasmo package",
    "package:firefox": "plasmo package --target=firefox-mv3",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "plasmo": "^0.90.5",
    "typescript": "^6.0.3"
  },
  "manifest": {
    "name": "Play Origin | Math game Mod Hack",
    "description": "The ultimate open-source mod loader for online math games.",
    "author": "ProdigyPXP",
    "permissions": [
      "declarativeNetRequest",
      "storage"
    ],
    "host_permissions": [
      "*://*.prodigygame.com/*",
      "https://raw.githubusercontent.com/*"
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "phex@prodigypxp.com"
      }
    }
  }
}
