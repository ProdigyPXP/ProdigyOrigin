{
  "icons": {
    "16": "./gen-assets/icon16.plasmo.png",
    "32": "./gen-assets/icon32.plasmo.png",
    "48": "./gen-assets/icon48.plasmo.png",
    "64": "./gen-assets/icon64.plasmo.png",
    "128": "./gen-assets/icon128.plasmo.png"
  },
  "manifest_version": 3,
  "action": {
    "default_icon": {
      "16": "./gen-assets/icon16.plasmo.png",
      "32": "./gen-assets/icon32.plasmo.png",
      "48": "./gen-assets/icon48.plasmo.png",
      "64": "./gen-assets/icon64.plasmo.png",
      "128": "./gen-assets/icon128.plasmo.png"
    },
    "default_popup": "./popup.html"
  },
  "version": "4.1.0",
  "author": "ProdigyPXP",
  "name": "Prodigy Origin | Prodigy Mod Hack",
  "description": "The ultimate open source mod loader for Prodigy Math Game",
  "background": {
    "service_worker": "./static/background/index.ts"
  },
  "permissions": [
    "scripting",
    "declarativeNetRequest",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://math.prodigygame.com/*"
      ],
      "js": [
        "../contents/origin-bridge.ts"
      ],
      "run_at": "document_start"
    }
  ],
  "host_permissions": [
    "*://*.prodigygame.com/*",
    "https://raw.githubusercontent.com/*"
  ]
}
